{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit(./AGENTS.md)",
      "Write(./AGENTS.md)",
      "Edit(./CLAUDE.md)",
      "Write(./CLAUDE.md)",
      "Edit(./**/AGENTS.md)",
      "Write(./**/AGENTS.md)",
      "Edit(./**/CLAUDE.md)",
      "Write(./**/CLAUDE.md)",
      "Edit(./.vscode/settings.json)",
      "Write(./.vscode/settings.json)",
      "Edit(./.claude/settings.json)",
      "Edit(./.claude/agent-base.json)",
      "Write(./.claude/agent-base.json)"
    ],
    "ask": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/skills/docs/scripts/docs-nudge.mjs session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/skills/docs/scripts/docs-nudge.mjs stop"
          }
        ]
      }
    ]
  }
}
