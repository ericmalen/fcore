{
  // ===== Instructions =====
  // AGENTS.md at the repo root is the canonical repo-wide instructions file.
  // Copilot, Cursor, Codex, Aider, Gemini CLI, and others read it directly.
  // Claude Code reads CLAUDE.md, which imports AGENTS.md via `@AGENTS.md`.
  "chat.useAgentsMdFile": true,
  // (chat.useNestedAgentsMdFiles is set only when the nested-AGENTS.md compat
  // mechanism is in use — this repo has none; see R-45/R-53.)
  // CLAUDE.md only imports AGENTS.md — Copilot already reads AGENTS.md natively,
  // so leave this off to avoid loading the same content twice.
  "chat.useClaudeMdFile": false,

  // ===== Monorepo discovery =====
  // Discover customizations from parent folders up to the repo root so that a
  // package-level .claude/ or .github/ is picked up in addition to the root.
  "chat.useCustomizationsInParentRepositories": true,

  // ===== Skills =====
  // Skills live in .claude/skills/, one of Copilot's default search paths
  // (alongside .github/skills/ and the tool-agnostic .agents/skills/) — so no
  // chat.agentSkillsLocations override is needed. Claude Code reads the same
  // folder. One copy, both tools.
  "chat.useAgentSkills": true,

  // ===== Agents / subagents =====
  // Custom agents live in .claude/agents/ (Claude subagent format). Copilot
  // detects them there and maps Claude tool names automatically.
  // Enable lifecycle hooks (SessionStart, PostToolUse, Stop, …) defined in a
  // specific agent's frontmatter.
  "chat.useCustomAgentHooks": true,
  // Allow subagents to invoke subagents. Depth capped at 5 by VS Code; no
  // cycle detection. agent-base still prefers flat orchestration as a
  // default — nesting is available for legitimate compositional cases.
  "chat.subagents.allowInvocationsFromSubagents": true,

  // ===== File nesting =====
  // Collapse CLAUDE.md under AGENTS.md in the explorer — they're a cross-tool
  // pair (same content, different entry point per tool) and don't need to be
  // visually separate.
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "AGENTS.md": "CLAUDE.md"
  },

  // ===== Terminal auto-approve (use cautiously) =====
  // Explicitly disabled so users opt in consciously. Leave the allow-list
  // empty until specific commands are reviewed and added.
  "chat.tools.terminal.enableAutoApprove": false,
  "chat.tools.terminal.autoApprove": []
}
